{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "permission": {
    "bash": {
      "*": "allow",
      "git commit": "ask"
    },
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "doom_loop": "allow",
    "skill": "allow",
    "external_directory": {
      "*": "allow"
    }
  }
}