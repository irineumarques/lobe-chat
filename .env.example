# ============================================
# MouseAI - Environment Configuration
# ============================================
# IMPORTANT: Copy this file to .env and fill in the real values
# DO NOT commit .env to version control!

# ============================================
# Server
# ============================================
LOBE_PORT=3210
APP_URL=http://localhost:3210

# ============================================
# Security Secrets (generate with: openssl rand -base64 32)
# ============================================
AUTH_SECRET=YOUR_AUTH_SECRET_HERE
KEY_VAULTS_SECRET=YOUR_KEY_VAULTS_SECRET_HERE

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE
POSTGRES_PORT=5432
LOBE_DB_NAME=mouseai

# ============================================
# Redis
# ============================================
REDIS_PORT=6379

# ============================================
# S3 / MinIO
# ============================================
S3_ACCESS_KEY_ID=YOUR_MINIO_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_MINIO_SECRET_KEY
S3_BUCKET=mouseai
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================
# AI Provider - Anthropic
# ============================================
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
ANTHROPIC_PROXY_URL=https://api.aicortex.vip
ANTHROPIC_CLIENT_TIMEOUT=295000

# ============================================
# AI Provider - DeepSeek
# ============================================
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
DEEPSEEK_PROXY_URL=https://api.deepseek.com/v1

# ============================================
# MCP Servers
# ============================================
MCP_TOOL_TIMEOUT=60000

# Code Interpreter MCP
CODE_INTERPRETER_MCP_URL=http://localhost:3104

# GitHub MCP Server
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# PostgreSQL Readonly MCP Server
POSTGRES_READONLY_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?options=-c%20default_transaction_read_only%3Don

# PostgreSQL Readonly MCP Server
POSTGRES_READONLY_URL=postgresql://postgres:MouseAI2024!Secure@postgresql:5432/mouseai?options=-c%20default_transaction_read_only%3Don

# ============================================
# Code Interpreter
# ============================================
CODE_INTERPRETER_PORT=8080
CODE_INTERPRETER_API_KEY=YOUR_CODE_INTERPRETER_API_KEY_HERE
CODE_INTERPRETER_API_URL=http://code-interpreter:8080

# ============================================
# Web Search
# ============================================
SERPER_API_KEY=YOUR_SERPER_API_KEY_HERE
FIRECRAWL_API_KEY=YOUR_FIRECRAWL_API_KEY_HERE
SEARXNG_SECRET=YOUR_SEARXNG_SECRET_HERE
SEARXNG_PORT=8081

# ============================================
# GitLab UFAL
# ============================================
GITLAB_UFAL_TOKEN=YOUR_GITLAB_TOKEN_HERE
GITLAB_UFAL_BASE_URL=https://gitlab.ufal.br/api/v4
